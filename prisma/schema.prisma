generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String
  price       Float
  imageUrl    String
  createdAt   DateTime @default(now())
}

model Seller {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String
  phone String
}
